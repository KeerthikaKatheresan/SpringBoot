-------------------------------------------
Validation annotation:
@NotBlank-for checking string is not blank
@NotNull-for checking value is not Null
@Email
@Size(min=,max=)
@Min,@Max
-----------------------------
In controller you should use @Valid in function argument then only these validation will be activated
----------------------------
Student.java
@Entity
@Table(name="student")
public class Student
{
    @Id
    @GeneratedValue(strategy=GenerationType.IDENTITY)
    private Integer id;
    
    @Column(name="StudentName")
    @NotBlank(message="Name cannot be blank")
    private String name;
    
    @Email(message="Valid email is required")
    @NotBlank(message="Email cannot be blank")
    private String email;
    
    @NotNull(message="Salary cannot be null")
    private Double salary;
    
    @Min(value=18,message="Age should be above 18")
    private Integer age;
    
     @Size(min=3,max=20)
    private String parentName;
    
    @Max(value=60,message="Age should be less than 60")
    private Integer parentAge;
    
   
    
    //getter and setter
    //default contructor & parameterized constructor
    //toString
}
